# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
# For LAN access from other devices, frontend uses a proxy; backend only sees 127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL en 192.168.0.115)
DB_NAME=fitness_coach
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=192.168.0.115
DB_PORT=5432
# Si usas DATABASE_URL, debe apuntar al mismo host:
DATABASE_URL=postgresql://postgres:postgres@192.168.0.115:5432/fitness_coach

# Email (for notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=5
JWT_REFRESH_TOKEN_LIFETIME=1

# Internal API (MCP / server-to-server). Required for /api/internal/*
INTERNAL_API_TOKEN=your-internal-api-token-change-in-production

# OpenAI (training recommendations & feedback analysis)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
